# --- Core ---------------------------------------------------------------
# WireGuard address:port this agent binds to. NEVER 0.0.0.0 — the agent
# must only be reachable through the tunnel from the scheduler.
LISTEN_ADDR=10.10.0.2:7777
# Shared secret from `POST /admin/hosts` (devplat-backend) when this host
# was registered. Used both ways: required on every inbound request here,
# sent as Bearer auth on outbound heartbeats.
AGENT_TOKEN=CHANGE_ME
# Backend's public base URL — heartbeats go here over the public internet,
# not the tunnel (see internal/heartbeat/heartbeat.go for why).
SCHEDULER_URL=https://api.devplat.ch

# --- Images ---------------------------------------------------------------
# Built by image/build-golden-image.sh. Point at a specific version or at
# the "current" symlink to always track the newest build.
GOLDEN_IMAGE_PATH=/opt/devplat/agent/images/current/rootfs.ext4
# Fetched by image/fetch-kernel.sh.
KERNEL_IMAGE_PATH=/opt/devplat/agent/images/vmlinux.bin
FIRECRACKER_BINARY=/usr/local/bin/firecracker
VM_STATE_DIR=/var/lib/devplat/vms

# --- Sizing -----------------------------------------------------------------
# Per-VM sizing (vCPU/RAM) is NOT configured here — it arrives on each
# POST /vms request as the requesting team's plan cap, set by the scheduler
# (see devplat-backend's plans table). This agent enforces that size as the
# VM's hard Firecracker/cgroup limit and admits it against the host-wide
# budget below.
#
# HOST_RESERVED_RAM_MB is subtracted from detected physical RAM before
# computing how much VM capacity fits — headroom for the host OS, the registry
# cache container, and this agent itself. NOTE: when registering this host via
# POST /admin/hosts, use the *post-reservation* capacity (what this agent will
# actually offer), not the raw hardware spec, so the scheduler's accounting
# matches what the agent reports on GET /health.
HOST_RESERVED_RAM_MB=8192
DEFAULT_TTL_MINUTES=60
REAPER_INTERVAL_SECONDS=30
HEARTBEAT_INTERVAL_SECONDS=20

# --- Networking ---------------------------------------------------------
# First address of this host's /16 VM pool. Give Host A and Host B
# different pools (e.g. 172.20.0.0 / 172.21.0.0) so their tap subnets never
# collide if the hosts ever end up routable to each other.
TAP_IP_BASE=172.20.0.0
# host_port = DOCKER_PORT_BASE + slot; DNAT'd to that VM's Docker daemon.
DOCKER_PORT_BASE=10000
# Only this CIDR may reach any VM's Docker port — the WireGuard tunnel
# subnet the scheduler lives on.
WIREGUARD_CIDR=10.10.0.0/24
BANDWIDTH_CAP_MBIT=200
